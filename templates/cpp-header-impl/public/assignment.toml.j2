[assignment]
slug = "{{ assignment_slug }}"
name = "{{ assignment_name }}"
author = "{{ author }}"
description = "{{ description }}"
version = "0.1.0"
status = "draft"

[classification]
language = "cpp"
difficulty = "{{ difficulty }}"
topics = []
labels = ["starter-code"]

[template]
slug = "cpp-header-impl"
version = "0.1"

[grader]
visibility = "visible"
stdout_visibility = "after_due_date"

[grader.dependencies]
system = ["cmake", "g++", "valgrind"]
