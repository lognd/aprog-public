from pathlib import Path

from lograder.pipeline.build.bash_script import BashScriptBuild
from lograder.pipeline.build.prebuilt import PrebuiltArtifacts
from lograder.pipeline.input.local_directory import LocalDirectory
from lograder.pipeline.pipeline import Pipeline
from lograder.pipeline.score import AllOrNothingScorer, TestCaseScorer
from lograder.pipeline.test.output_compare import ComparisonMode, OutputCompareCase, OutputCompareTest
from lograder.pipeline.types.artifacts import FileArtifact

# Java: compile with javac, then run with java. The build script compiles
# all .java files in the submission directory.
_ARTIFACT_NAME = "{{ artifact_name }}"

_CASES = [
    OutputCompareCase(
        name="test_example",
        args=[],
        stdin="",
        expected_stdout="",
        comparison=ComparisonMode.STRIP,
    ),
]

_BUILD_SCORER = AllOrNothingScorer(0.0, label="Build")
_TEST_SCORER = TestCaseScorer({"test_example": 10.0}, label="{{ assignment_name }} Correctness")


def make_pipeline() -> Pipeline:
    from lograder.pipeline.config import get_config

    step = LocalDirectory()
    build = BashScriptBuild(script=Path(__file__).parent / "build.sh")
    build.scorer = _BUILD_SCORER
    # After build.sh runs, provide the compiled class directory as a shell-wrapped artifact.
    artifacts = PrebuiltArtifacts(
        {_ARTIFACT_NAME: FileArtifact(Path(__file__).parent / "run.sh")}
    )
    tests = OutputCompareTest(_ARTIFACT_NAME, _CASES)
    tests.scorer = _TEST_SCORER
    return Pipeline([step, build, artifacts, tests])
