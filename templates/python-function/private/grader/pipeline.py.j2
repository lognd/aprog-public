from lograder.pipeline.build.prebuilt import PrebuiltArtifacts
from lograder.pipeline.input.local_directory import LocalDirectory
from lograder.pipeline.pipeline import Pipeline
from lograder.pipeline.score import TestCaseScorer
from lograder.pipeline.test.output_compare import ComparisonMode, OutputCompareCase, OutputCompareTest
from lograder.pipeline.types.artifacts import FileArtifact

# Student submits a Python file. The grader wraps it with a driver that calls
# the required function(s) and prints results. Place the driver at grader/driver.py.
_ARTIFACT_NAME = "driver.py"

# FILL IN: Add test cases. stdin passes arguments to the driver.
_CASES = [
    OutputCompareCase(
        name="test_example",
        args=[],
        stdin="",
        expected_stdout="",
        comparison=ComparisonMode.STRIP,
    ),
]

# FILL IN: Assign point values per case.
_TEST_SCORER = TestCaseScorer({"test_example": 10.0}, label="{{ assignment_name }} Correctness")


def make_pipeline() -> Pipeline:
    from lograder.pipeline.config import get_config
    from pathlib import Path

    grader_dir = Path(__file__).parent

    step = LocalDirectory()
    # driver.py is staff-authored; it imports the student's module from the submission dir.
    artifacts = PrebuiltArtifacts({_ARTIFACT_NAME: FileArtifact(grader_dir / _ARTIFACT_NAME)})
    tests = OutputCompareTest(_ARTIFACT_NAME, _CASES)
    tests.scorer = _TEST_SCORER
    return Pipeline([step, artifacts, tests])
