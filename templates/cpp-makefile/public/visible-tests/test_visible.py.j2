import subprocess
from pathlib import Path


def run(stdin: str) -> str:
    result = subprocess.run(
        [str(Path(__file__).parent.parent / "{{ artifact_name }}")],
        input=stdin,
        capture_output=True,
        text=True,
        timeout=10,
    )
    return result.stdout


